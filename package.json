{
  "name": "n8n-nodes-localith",
  "version": "0.1.8",
 
"description": "n8n community node for Localith — access your Google Business reviews, listings, and location metrics. Build automations, dashboards, or your own reputation management platform.",
"keywords": [
  "n8n-community-node-package",
  "n8n",
  "localith",
  "google business profile",
  "google business api",
  "gbp",
  "reviews",
  "google reviews",
  "reputation management",
  "listings",
  "location management",
  "review automation",
  "multi-location",
  "local seo",
  "embedsocial",
  "social proof"
  
],
  "license": "MIT",
  "homepage": "https://github.com/localith/n8n-nodes-localith",
  "author": {
    "name": "Localith",
    "email": "support@localith.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/localith/n8n-nodes-localith.git"
  },
  "bugs": {
    "url": "https://github.com/localith/n8n-nodes-localith/issues"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && cp nodes/Localith/localith.svg dist/nodes/Localith/localith.svg",
    "dev": "n8n-node dev",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials --ext .ts",
    "lint:fix": "eslint nodes credentials --ext .ts --fix",
    "prepublishOnly": "npm run build "
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/LocalithApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Localith/Localith.node.js"
    ],
  "iconUrl": "file:dist/nodes/Localith/localith.svg"},
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@n8n/eslint-plugin-community-nodes": "*",
    "@n8n/node-cli": "*",
    "@types/node": "^22.0.0",
    "eslint": "^10.0.2",
    "n8n-workflow": "^2.11.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=8.0.0"
  }
}
